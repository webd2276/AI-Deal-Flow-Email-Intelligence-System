    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Normalize financial values - remove symbols, convert K/M/B to numbers\nfunction normalizeFinancial(value) {\n  if (typeof value === 'number') {\n    return value;\n  }\n  \n  if (!value || typeof value !== 'string') {\n    return 0;\n  }\n  \n  // Remove currency symbols, commas, spaces\n  let cleaned = value\n    .replace(/[$€£¥,\\s]/g, '')\n    .trim()\n    .toUpperCase();\n  \n  if (!cleaned) {\n    return 0;\n  }\n  \n  // Handle K, M, B multipliers\n  let multiplier = 1;\n  if (cleaned.endsWith('K')) {\n    multiplier = 1000;\n    cleaned = cleaned.slice(0, -1);\n  } else if (cleaned.endsWith('M')) {\n    multiplier = 1000000;\n    cleaned = cleaned.slice(0, -1);\n  } else if (cleaned.endsWith('B')) {\n    multiplier = 1000000000;\n    cleaned = cleaned.slice(0, -1);\n  }\n  \n  // Parse the number\n  const num = parseFloat(cleaned);\n  return isNaN(num) ? 0 : Math.round(num * multiplier);\n}\n\nconst data = $input.item.json;\n\nreturn {\n  json: {\n    companyName: data.companyName || '',\n    industry: data.industry || '',\n    businessModel: data.businessModel || '',\n    location: data.location || '',\n    askingPrice: normalizeFinancial(data.askingPrice),\n    revenue: normalizeFinancial(data.revenue),\n    ebitda: normalizeFinancial(data.ebitda),\n    cashFlow: normalizeFinancial(data.cashFlow),\n    contactName: data.contactName || '',\n    contactEmail: data.contactEmail || '',\n    brokerName: data.brokerName || '',\n    website: data.website || '',\n    dealSummary: data.dealSummary || '',\n    investmentHighlights: data.investmentHighlights || '',\n    risks: data.risks || '',\n    confidenceScore: parseInt(data.confidenceScore) || 0,\n    dealQualityScore: parseInt(data.dealQualityScore) || 0\n  }\n};"
      },
