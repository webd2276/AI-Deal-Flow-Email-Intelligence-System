    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Extract and clean HTML email body\nconst emailBody = $input.item.json.body?.content || '';\n\n// Remove HTML tags\nlet cleanText = emailBody\n  .replace(/<style[^>]*>.*?<\\/style>/gis, '')\n  .replace(/<script[^>]*>.*?<\\/script>/gis, '')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .replace(/&quot;/g, '\"');\n\n// Remove excessive whitespace\ncleanText = cleanText\n  .replace(/\\s+/g, ' ')\n  .replace(/\\n\\s*\\n/g, '\\n')\n  .trim();\n\n// Try to remove common email signatures\nconst signaturePatterns = [\n  /Best regards[\\s\\S]*$/i,\n  /Sincerely[\\s\\S]*$/i,\n  /Thanks[\\s\\S]*$/i,\n  /Sent from my [\\s\\S]*$/i,\n  /--[\\s\\S]*$/\n];\n\nfor (const pattern of signaturePatterns) {\n  const match = cleanText.match(pattern);\n  if (match && match.index > 200) {\n    cleanText = cleanText.substring(0, match.index).trim();\n    break;\n  }\n}\n\nreturn {\n  json: {\n    cleanEmailBody: cleanText,\n    subject: $input.item.json.subject,\n    sender: $input.item.json.from?.emailAddress?.address || '',\n    senderName: $input.item.json.from?.emailAddress?.name || '',\n    receivedDateTime: $input.item.json.receivedDateTime,\n    webLink: $input.item.json.webLink,\n    messageId: $input.item.json.internetMessageId\n  }\n};"
      },
      "id": "9c06d3e0-9357-462d-aa2a-025068cc8d8d",
      "name": "Clean HTML Email Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        160,
        368
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "aiPrompt",
              "value": "=You are a business acquisition data extraction specialist. Extract structured information from the following broker email about a business acquisition opportunity.\n\nEMAIL SUBJECT: {{ $json.subject }}\nEMAIL BODY:\n{{ $json.cleanEmailBody }}\n\nCRITICAL INSTRUCTIONS:\n1. Return ONLY raw valid JSON - NO markdown, NO code blocks, NO explanations\n2. Use these exact field names\n3. If data is missing, use empty string \"\"\n4. Convert ALL money abbreviations to full numbers:\n   - K = thousand (e.g., 850K = 850000)\n   - M = million (e.g., 3.5M = 3500000)\n   - B = billion (e.g., 1.2B = 1200000000)\n5. Return numbers WITHOUT currency symbols or commas\n6. Include a confidence score (1-10) and deal quality score (1-10)\n\nREQUIRED JSON STRUCTURE:\n{\n  \"companyName\": \"\",\n  \"industry\": \"\",\n  \"businessModel\": \"\",\n  \"location\": \"\",\n  \"askingPrice\": 0,\n  \"revenue\": 0,\n  \"ebitda\": 0,\n  \"cashFlow\": 0,\n  \"contactName\": \"\",\n  \"contactEmail\": \"\",\n  \"brokerName\": \"\",\n  \"website\": \"\",\n  \"dealSummary\": \"\",\n  \"investmentHighlights\": \"\",\n  \"risks\": \"\",\n  \"confidenceScore\": 0,\n  \"dealQualityScore\": 0\n}",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "id": "17d3c137-0997-4d01-aa45-6112733f59d0",
      "name": "Build Claude AI Prompt",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        480,
        368
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Extract Claude response safely\nconst response = $input.item.json;\nlet extractedData = null;\nlet parseSuccess = false;\n\ntry {\n  // Get the text content from Claude response\n  const contentText = response.content?.[0]?.text || '';\n  \n  if (!contentText) {\n    throw new Error('No content in Claude response');\n  }\n  \n  // Try to parse JSON directly\n  try {\n    extractedData = JSON.parse(contentText);\n    parseSuccess = true;\n  } catch (e) {\n    // If direct parse fails, try to extract JSON from markdown code blocks\n    const jsonMatch = contentText.match(/```(?:json)?\\s*([\\s\\S]*?)\\s*```/);\n    if (jsonMatch) {\n      extractedData = JSON.parse(jsonMatch[1]);\n      parseSuccess = true;\n    } else {\n      // Try to find JSON object in text\n      const objectMatch = contentText.match(/\\{[\\s\\S]*\\}/);\n      if (objectMatch) {\n        extractedData = JSON.parse(objectMatch[0]);\n        parseSuccess = true;\n      } else {\n        throw new Error('Could not extract JSON from response');\n      }\n    }\n  }\n  \n  // Validate required fields exist\n  const requiredFields = ['companyName', 'askingPrice', 'revenue', 'ebitda'];\n  for (const field of requiredFields) {\n    if (!(field in extractedData)) {\n      extractedData[field] = field === 'companyName' ? '' : 0;\n    }\n  }\n  \n} catch (error) {\n  // Fallback: create empty structure\n  extractedData = {\n    companyName: '',\n    industry: '',\n    businessModel: '',\n    location: '',\n    askingPrice: 0,\n    revenue: 0,\n    ebitda: 0,\n    cashFlow: 0,\n    contactName: '',\n    contactEmail: '',\n    brokerName: '',\n    website: '',\n    dealSummary: '',\n    investmentHighlights: '',\n    risks: '',\n    confidenceScore: 0,\n    dealQualityScore: 0\n  };\n  parseSuccess = false;\n}\n\nreturn {\n  json: {\n    ...extractedData,\n    parseSuccess: parseSuccess,\n    rawResponse: response.content?.[0]?.text || ''\n  }\n};"
      },
